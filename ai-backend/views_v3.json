{
  "holdingsCentric": {
    "description": "Organize case data by Holdings with hierarchical relationships",
    "topLevel": {
      "case": {
        "label": "Case",
        "single": true
      },
      "proceedings": {
        "label": "Proceeding",
        "via": "HAS_PROCEEDING",
        "from": "Case"
      },
      "parties": {
        "label": "Party",
        "via": "INVOLVES",
        "from": "Proceeding"
      },
      "forums": {
        "label": "Forum",
        "via": "HEARD_IN",
        "from": "Proceeding"
      },
      "jurisdictions": {
        "label": "Jurisdiction",
        "via": "PART_OF",
        "from": "Forum"
      }
    },
    "issues": {
      "root": "Issue",
      "structure": {
        "issue": {
          "self": true
        },
        "ruling": {
          "via": "SETS",
          "direction": "incoming",
          "single": true,
          "include": {
            "law": {
              "via": "RELIES_ON_LAW",
              "label": "Law"
            },
            "relief": {
              "via": "RESULTS_IN",
              "label": "Relief",
              "include": {
                "reliefTypes": {
                  "via": "IS_TYPE",
                  "label": "ReliefType",
                  "single": true
                }
              }
            },
            "arguments": {
              "via": "EVALUATED_IN",
              "direction": "incoming",
              "label": "Argument",
              "include": {
                "doctrine": {
                  "via": "RELATES_TO_DOCTRINE",
                  "label": "Doctrine"
                },
                "factPattern": {
                  "via": "RELATES_TO_FACTPATTERN",
                  "label": "FactPattern"
                },
                "policy": {
                  "via": "RELATES_TO_POLICY",
                  "label": "Policy"
                }
              }
            }
          }
        }
      }
    }
  }
}